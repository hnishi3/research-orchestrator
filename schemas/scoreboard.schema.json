{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scoreboard",
  "type": "object",
  "additionalProperties": true,
  "$defs": {
    "metric_stats": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mean"],
      "properties": {
        "mean": { "type": "number" },
        "std": { "type": ["number", "null"] },
        "n_runs": { "type": ["integer", "null"], "minimum": 1 },
        "seeds": { "type": ["array", "null"], "items": { "type": "integer" } },
        "ci_95": { "type": ["array", "null"], "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "raw_values": { "type": ["array", "null"], "items": { "type": "number" } }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string" },
    "primary_metric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "direction", "current"],
      "properties": {
        "name": { "type": "string" },
        "direction": { "type": "string", "enum": ["maximize", "minimize"] },
        "current": {
          "oneOf": [
            { "type": "null" },
            { "type": "number" },
            { "$ref": "#/$defs/metric_stats" }
          ]
        },
        "best": {
          "oneOf": [
            { "type": "null" },
            { "type": "number" },
            { "$ref": "#/$defs/metric_stats" }
          ]
        },
        "baseline": {
          "oneOf": [
            { "type": "null" },
            { "type": "number" },
            { "$ref": "#/$defs/metric_stats" }
          ]
        },
        "delta_vs_baseline": { "type": ["number", "null"] }
      }
    },
    "metrics": {
      "description": "Additional metrics (multi-objective); interpretation is domain-specific.",
      "oneOf": [
        { "type": "object", "additionalProperties": true },
        { "type": "array", "items": {} },
        { "type": "null" }
      ]
    },
    "runs": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "notes": { "type": "string" }
  }
}
