{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IdeaRecord",
  "type": "object",
  "required": [
    "id",
    "title",
    "one_sentence_claim",
    "contribution_type",
    "target_venues",
    "novelty_statement",
    "evaluation_plan",
    "feasibility",
    "risks",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique idea id"
    },
    "title": {
      "type": "string"
    },
    "one_sentence_claim": {
      "type": "string",
      "description": "One-sentence claim (assertive)."
    },
    "contribution_type": {
      "type": "string",
      "enum": [
        "method",
        "system",
        "dataset",
        "analysis",
        "survey",
        "replication"
      ]
    },
    "target_venues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "novelty_statement": {
      "type": "string",
      "description": "One-line differentiation from closest prior work."
    },
    "evaluation_plan": {
      "type": "object",
      "required": [
        "datasets",
        "metrics",
        "baselines",
        "ablations"
      ],
      "properties": {
        "datasets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "baselines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ablations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "feasibility": {
      "type": "object",
      "required": [
        "estimated_gpu_hours",
        "estimated_calendar_days",
        "blocking_dependencies"
      ],
      "properties": {
        "estimated_gpu_hours": {
          "type": "number",
          "minimum": 0
        },
        "estimated_calendar_days": {
          "type": "number",
          "minimum": 0
        },
        "blocking_dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "risks": {
      "type": "object",
      "required": [
        "ethics",
        "license",
        "safety",
        "reproducibility"
      ],
      "properties": {
        "ethics": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "safety": {
          "type": "string"
        },
        "reproducibility": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "title",
          "url",
          "retrieved_at",
          "summary",
          "relevance"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "paper",
              "blog",
              "doc",
              "dataset",
              "benchmark",
              "repo"
            ]
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "retrieved_at": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "relevance": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "novelty": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "feasibility": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "impact": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "clarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "reusability": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "risk_penalty": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "total": {
          "type": "number"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "active",
        "rejected",
        "smoke_passed",
        "selected",
        "parked",
        "done"
      ],
      "default": "candidate"
    },
    "parent_idea_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional parent idea id for lineage / branching."
    },
    "rejection_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "parked_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "unblock_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_check_date": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional reminder date for revisiting parked ideas."
    },
    "reusable_assets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths/URLs that can be reused when reviving/spawning."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "bsc",
        "msc",
        "phd"
      ]
    }
  }
}
